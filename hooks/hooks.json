{
  "description": "Converse plugin hooks — session id injection + TTS handoff",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Monitor",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/claude/inject-session-id.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/claude/speak-hook.js",
            "async": true
          }
        ]
      }
    }
  }
}
