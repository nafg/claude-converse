{
  "description": "Converse plugin hooks — session ID export + TTS",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"export CLAUDE_SESSION_ID=$(jq -r .session_id)\" >> \"$CLAUDE_ENV_FILE\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/speak.py",
            "async": true
          }
        ]
      }
    ]
  }
}
